# НЕ ЗАЛИВАТЬ реальные ключи на GitHub.
# Для Cloudflare Pages добавляй эти значения в:
# Cloudflare Dashboard -> Workers & Pages -> твой проект -> Settings -> Environment variables

# URL твоего Pages-проекта, появится после первого деплоя:
MINI_APP_URL=https://tele-kopai.pages.dev
APP_BASE_URL=https://tele-kopai.pages.dev
APP_NAME=Tele-Копай!

# Telegram token нужен только если хочешь, чтобы /start отвечал кнопкой.
# Если используешь только /setmenubutton в BotFather, BOT_TOKEN можно не добавлять.
BOT_TOKEN=8955626692:AAHYk8f96GHwOLEobXMVwGH0pMh2Q4SANN0

# OpenRouter. Создай ключ здесь: https://openrouter.ai/settings/keys
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=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

# ВАЖНО: бесплатные модели в OpenRouter меняются.
# Открой https://openrouter.ai/models?max_price=0 и выбери vision/image модель.
# Пример оставлен как место для правки, замени на актуальную бесплатную vision-модель.
OPENROUTER_MODEL=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
